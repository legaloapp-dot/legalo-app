# Supabase - Obtén estos valores en https://supabase.com/dashboard
EXPO_PUBLIC_SUPABASE_URL=tu_url_de_supabase
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key

# Fee en USD mostrado al cliente (pago móvil / comprobante)
EXPO_PUBLIC_FEE_USD=25

# Solo para scripts locales (create-test-user.js, seed-demo-data.js) — nunca en builds públicos
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# Gemini API - Para el chatbot de diagnóstico legal
EXPO_PUBLIC_GEMINI_API_KEY=tu_api_key_de_gemini
