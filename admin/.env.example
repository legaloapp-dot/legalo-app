# Público (solo URL y anon en el navegador si usas cliente; el panel usa sobre todo servidor)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key

# Solo servidor — nunca exponer al cliente (CRUD admin, Storage, Auth admin)
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# Opcional — script: npm run create-superadmin
# SUPERADMIN_EMAIL=admin@tu-dominio.com
# SUPERADMIN_PASSWORD=UnaClaveSegura123!
# SUPERADMIN_NAME=Administrador
